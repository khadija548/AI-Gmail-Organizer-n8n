    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an email triage assistant. Analyse the email below and return structured JSON.\n\nRules:\n- \"category\" MUST be exactly one of: Important, University, Assignment, Internship, Job, Personal, Shopping, Banking, Promotion, Spam, Other.\n- \"priority\" MUST be exactly one of: High, Medium, Low.\n- \"replyRequired\" is true only when the email genuinely needs a personal reply from the recipient (a direct question, request, or actionable message). Newsletters, promotions, notifications, receipts and spam are false.\n- When replyRequired is true, write a concise, polite, professional \"replyBody\" as if written by the recipient (no placeholders, no \"here is a draft\" preamble) and a matching \"replySubject\". When false, set replyBody to \"\" and replySubject to \"\".\n\n--- EMAIL ---\nSubject: {{ $json.subject || ($json.headers && $json.headers.subject) }}\nFrom: {{ ($json.headers && $json.headers.from) || $json.from }}\n\nBody:\n{{ $json.text || $json.textAsHtml || $json.snippet }}",
        "hasOutputParser": true,
        "batching": {}
      },
      "id": "4a434d1d-b70e-4b5f-af11-0c60f680745b",
      "name": "Classify Email",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        224,
        304
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "options": {
          "temperature": 0.2
        }
      },
      "id": "6c5b01ef-0f4a-4422-ad95-ec108ec46574",
      "name": "Gemini Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1.1,
      "position": [
        240,
        528
      ],
      "credentials": {
        "googlePalmApi": {
          "id": "OSbzI8dGz4txDG7I",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "jsonSchemaExample": "{\"category\":\"University\",\"priority\":\"High\",\"replyRequired\":true,\"replySubject\":\"Re: Course registration deadline\",\"replyBody\":\"Hi,\\n\\nThank you for the reminder. I will complete my registration before the deadline.\\n\\nBest regards\"}"
      },
      "id": "956c0e15-5a06-457b-b09f-1cbfb7b8cf26",
      "name": "Classification Schema",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        368,
        528
      ]
    },
    {
      "parameters": {
        "jsCode": "const validCategories = ['Important','University','Assignment','Internship','Job','Personal','Shopping','Banking','Promotion','Spam','Other'];\nconst labels = $('Get Existing Labels').all().map(i => i.json);\nconst emails = $('Gmail Trigger').all();\nconst classified = $input.all();\nconst results = [];\nfor (let i = 0; i < classified.length; i++) {\n  const out = classified[i].json.output || classified[i].json || {};\n  const email = emails[i] ? emails[i].json : {};\n  let category = String(out.category || 'Other').trim();\n  if (!validCategories.some(c => c.toLowerCase() === category.toLowerCase())) { category = 'Other'; }\n  else { category = validCategories.find(c => c.toLowerCase() === category.toLowerCase()); }\n  let priority = String(out.priority || 'Medium').trim();\n  if (!['High','Medium','Low'].some(p => p.toLowerCase() === priority.toLowerCase())) { priority = 'Medium'; }\n  else { priority = ['High','Medium','Low'].find(p => p.toLowerCase() === priority.toLowerCase()); }\n  const replyRequired = out.replyRequired === true || out.replyRequired === 'true';\n  const match = labels.find(l => String(l.name || '').toLowerCase() === category.toLowerCase());\n  let fromAddr = '';\n  const f = email.from;\n  if (f) { if (typeof f === 'string') fromAddr = f; else if (f.value && f.value[0]) fromAddr = f.value[0].address; else if (f.text) fromAddr = f.text; }\n  if (!fromAddr && email.headers) fromAddr = email.headers.from || '';\n  const subject = email.subject || (email.headers && email.headers.subject) || '';\n  const body = email.text || email.textAsHtml || email.snippet || '';\n  const isAcademic = category === 'Assignment' || category === 'University';\n  results.push({ json: {\n    emailId: email.id,\n    threadId: email.threadId,\n    subject: subject,\n    from: fromAddr,\n    body: body,\n    category: category,\n    priority: priority,\n    replyRequired: replyRequired,\n    replySubject: out.replySubject || ('Re: ' + subject),\n    replyBody: out.replyBody || '',\n    labelName: category,\n    labelId: match ? match.id : '',\n    labelExists: !!match,\n    isAcademic: isAcademic,\n  } });\n}\nreturn results;"
      },
